---
interface Props {
  title?: string;
}
const { title } = Astro.props;
---

<div class="flow-step">
  {title && <div class="flow-title">{title}</div>}
  <slot />
</div>

<style>
  .flow-step {
    margin-bottom: var(--space-2);
  }
  .flow-title {
    font-size: var(--text-xs);
    color: var(--text-accent);
    margin-bottom: var(--space-1);
  }
</style>
